    {
      "id": "discurso-indireto",
      "titulo": "Discurso indireto (indirekte Rede)",
      "nivel": "B2",
      "descricao": "Relatar o que alguém disse. Usa-se formalmente o Konjunktiv I; na fala usa-se Konjunktiv II ou indicativo.",
      "regras": [
        {
          "id": "estrutura-discurso-indireto",
          "titulo": "Estrutura do discurso indireto",
          "nivel": "B2",
          "formas": [
