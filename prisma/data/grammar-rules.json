            { "tipo": "Sem dass (ordem do verbo: subordinada)", "exemplo": "Er sagt, er sei müde." }
          ],
          "ajuste_pronominal": "Os pronomes ajustam-se à perspetiva do relator: 'Ich bin krank' → Er sagt, er sei krank.",
          "exemplos": [
            { "de": "Direkt: 'Ich arbeite morgen nicht.' → Indirekt: Sie sagte, sie arbeite morgen nicht / sie würde morgen nicht arbeiten.", "pt": "Direto: 'Não trabalho amanhã.' → Indireto: Ela disse que não trabalharia amanhã." }
          ]
        }
      ]
    },

    {
      "id": "verbos-inseparaveis",
      "titulo": "Verbos inseparáveis (untrennbare Verben)",
      "nivel": "A2",
